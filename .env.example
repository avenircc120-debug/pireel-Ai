# ============================================================
# PIREEL — Variables d'environnement Vercel
# Copier chaque ligne dans : Vercel → Settings → Environment Variables
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_supabase

# ── GOOGLE GEMINI (provider par défaut) ───────────────────
# Ajoutez jusqu'à 10 clés pour la rotation automatique
# Obtenez vos clés sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-VOTRE_CLE_PRINCIPALE
# GEMINI_KEY_01=AIzaSy-VOTRE_CLE_01
# GEMINI_KEY_02=AIzaSy-VOTRE_CLE_02
# GEMINI_KEY_03=AIzaSy-VOTRE_CLE_03
# GEMINI_KEY_04=AIzaSy-VOTRE_CLE_04
# GEMINI_KEY_05=AIzaSy-VOTRE_CLE_05

# ── MOTEURS VIDÉO ─────────────────────────────────────────
DEFAULT_ENGINE=kling
KLING_API_KEY=votre_cle_kling
# LUMA_API_KEY=...
# RUNWAY_API_KEY=...
# PIKA_API_KEY=...

# ── APP ───────────────────────────────────────────────────
ALLOWED_ORIGIN=*
