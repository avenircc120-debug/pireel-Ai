# ============================================================
# PIREEL — Variables d'environnement Vercel
# Copier chaque ligne dans : Vercel → Settings → Environment Variables
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_supabase

# ── GROK xAI — 3 clés minimum (jusqu'à XAI_KEY_30) ───────
# → 3 clés tirées au hasard pour les 3 clips de 10s
# → Achetez des crédits sur console.x.ai avant utilisation
XAI_KEY_01=xai-VOTRE_CLE_01
XAI_KEY_02=xai-VOTRE_CLE_02
XAI_KEY_03=xai-VOTRE_CLE_03
# XAI_KEY_04=xai-VOTRE_CLE_04
# XAI_KEY_05=xai-VOTRE_CLE_05

# ── GROQ (priorité 2 — fallback texte) ────────────────────
# GROQ_KEY_01=gsk_...
# GROQ_KEY_02=gsk_...

# ── OPENAI (priorité 3 — fallback texte + vidéo Sora) ─────
# OPENAI_KEY_01=sk-...

# ── MISTRAL (priorité 4 — fallback texte) ─────────────────
# MISTRAL_KEY_01=...

# ── MOTEURS VIDÉO ─────────────────────────────────────────
DEFAULT_ENGINE=kling
KLING_API_KEY=votre_cle_kling
# LUMA_API_KEY=...
# RUNWAY_API_KEY=...
# PIKA_API_KEY=...

# ── APP ───────────────────────────────────────────────────
APP1_URL=https://votre-app1.com
ALLOWED_ORIGIN=*
